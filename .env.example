# TinyLog Configuration
# See: https://github.com/psylch/tinylog#configuration

# Path to your database file (required)
TINYLOG_DB=./agno_sessions.db

# Source type (auto-detected if omitted)
# Options: agno, langchain, autogen, google-adk, claude-agent-sdk, json
# TINYLOG_SOURCE_TYPE=auto

# Server port (default: 7892)
# TINYLOG_PORT=7892

# Admin key for authentication (optional, leave empty for no auth)
# TINYLOG_ADMIN_KEY=your-secret-key

# Host binding (default: 0.0.0.0)
# TINYLOG_HOST=0.0.0.0
